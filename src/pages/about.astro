---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Sobre Nosotros">
  <section class="py-16 px-8 text-center">
    <h2 class="text-3xl font-bold text-primary">Sobre Esbeltas Store</h2>
    <p class="mt-4 text-gray-700 max-w-2xl mx-auto">
      Somos una marca dedicada a ofrecer fajas colombianas de alta calidad,
      con más de 20 años de experiencia ayudando a mujeres a sentirse seguras,
      cómodas y bellas en su día a día.
    </p>
  </section>
</Layout>
