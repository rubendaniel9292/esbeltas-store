---
import Layout from "../../layouts/Layout.astro";
import collections from "../../data/collections.json";

const { slug } = Astro.params;
// Astro.params.slug puede ser undefined; asegurar que sea string antes de usarlo como índice
const category =
  typeof slug === "string"
    ? (collections as Record<string, any>)[slug]
    : undefined; // obtiene la categoría según la URL
const items = category ? category.items : [];

export async function getStaticPaths() {
  return Object.keys(collections).map((slug) => ({
    params: { slug },
  }));
}
---

<Layout title={category ? category.title : "Categoría"}>
  <section class="container mx-auto px-6 py-10">
    <h2 class="text-2xl text-center font-medium text-gray-700">
      {category ? category.title : "Categoría no encontrada"}
    </h2>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        items.map((item: any) => (
          <article class="bg-white rounded-lg shadow p-4">
            <img
              src={item.image}
              alt={item.name}
              class="h-56 w-full object-cover rounded-md"
            />
            <h3 class="mt-2 text-lg font-medium">{item.name}</h3>
            <p class="text-gray-600 text-sm mt-1">{item.description}</p>
            <a
              href={item.whatsappLink}
              target="_blank"
              class="mt-3 inline-block px-4 py-2 bg-green-500 text-white rounded-md hover:bg-green-600"
            >
              Lo quiero
            </a>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
